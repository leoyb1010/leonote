DATABASE_URL="file:../data/leonote.db"
AUTH_SECRET="change-me-to-a-long-random-secret"
LEONOTE_PUBLIC_URL="https://leonote.example.com"
LEONOTE_ALLOW_REGISTRATION="false"
AI_BASE_URL="https://api.deepseek.com"
AI_MODEL="deepseek-v4-flash"
AI_FALLBACK_MODEL="deepseek-v4-pro"
AI_EFFORT_LEVEL=""

# Briefing cron internal auth
BRIEFING_CRON_TOKEN="change-me-long-random-token"

# Optional public URL, used by cron worker to call internal API
LEONOTE_INTERNAL_URL="http://localhost:4317"

### Market APIs
FRED_API_KEY=""

# Briefing feature switch
BRIEFING_ENABLED="true"
BRIEFING_AUTO_REFRESH="true"
BRIEFING_MIN_ITEMS="24"
BRIEFING_MAX_AGE_MINUTES="5"
BRIEFING_TRANSLATE_ENGLISH="true"
BRIEFING_TRANSLATE_MAX_ITEMS="12"
BRIEFING_TRANSLATE_TIMEOUT_MS="30000"

# RSS proxy (optional)
HTTPS_PROXY=""
RSSHUB_BASE_URL="https://rsshub.app"

# Tavily Search (optional, fallback for RSS)
TAVILY_API_KEY=""

# X official API (optional, for important AI/tech people and organizations)
X_BEARER_TOKEN=""
# Format: username:display name:weight, comma-separated. Weight is 1-100.
BRIEFING_X_USERS="OpenAI:OpenAI:96,AnthropicAI:Anthropic:94,GoogleDeepMind:DeepMind:94,sama:Sam Altman:92,nvidia:NVIDIA:90,karpathy:Andrej Karpathy:88,github:GitHub:84"

# Horoscope refresh uses BRIEFING_CRON_TOKEN; no extra env required.
# The cron worker invalidates the in-memory cache at 00:01 Asia/Shanghai
# and retries at 06:30 if the RSS feed has not published the new day yet.
