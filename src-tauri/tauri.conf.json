{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Leonote",
  "version": "1.5.1",
  "identifier": "com.leo.leonote",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:4000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Leonote",
        "width": 1280,
        "height": 860,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "backgroundColor": "#080a0f",
        "titleBarStyle": "Overlay",
        "url": "{{LEONOTE_PUBLIC_URL}}"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https:; img-src 'self' data: blob:; object-src 'none'; base-uri 'self'; form-action 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
