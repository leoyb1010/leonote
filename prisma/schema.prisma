generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  name         String
  tokenVersion Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  notes        Note[]
  tags         Tag[]
  dailyNotes   DailyNote[]
  projects     Project[]

  // v1.5 Ledger
  expenseCategories ExpenseCategory[]
  expenses          Expense[]
}

model Note {
  id           String      @id @default(cuid())
  title        String
  content      String      @default("")
  excerpt      String      @default("")
  isFavorite   Boolean     @default(false)
  isPinned     Boolean     @default(false)
  isArchived   Boolean     @default(false)
  deletedAt    DateTime?
  source       String?
  lastViewedAt DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  userId       String
  projectId    String?
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  project      Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  tags         NoteTag[]
  dailyNotes   DailyNote[]
  revisions    NoteRevision[]

  @@index([userId, updatedAt])
  @@index([userId, deletedAt])
  @@index([userId, isArchived])
  @@index([userId, projectId])
}

model NoteRevision {
  id        String   @id @default(cuid())
  noteId    String
  userId    String
  title     String
  content   String
  excerpt   String   @default("")
  reason    String   @default("autosave")
  createdAt DateTime @default(now())

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId, createdAt])
  @@index([userId, createdAt])
}

model Tag {
  id        String    @id @default(cuid())
  name      String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes     NoteTag[]
  createdAt DateTime  @default(now())

  @@unique([name, userId])
}

model NoteTag {
  noteId String
  tagId  String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
}

model DailyNote {
  id        String   @id @default(cuid())
  date      DateTime
  noteId    String
  userId    String
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([date, userId])
  @@index([userId, date])
}

model AISetting {
  id                String   @id @default(cuid())
  userId            String   @unique
  baseUrl           String   @default("https://api.deepseek.com")
  apiKey            String   @default("")
  model             String   @default("deepseek-v4-flash")
  fallbackModel     String   @default("deepseek-v4-pro")
  enableAutoOrganize Boolean @default(true)
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())
}

model MemoryFact {
  id          String    @id @default(cuid())
  userId      String
  type        String    @default("preference")
  content     String
  confidence  Float     @default(0.7)
  isActive    Boolean   @default(true)
  sourceType  String?
  sourceId    String?
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())

  @@index([userId, isActive])
  @@index([userId, type])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  slug        String
  description String   @default("")
  status      String   @default("active")
  color       String   @default("slate")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes       Note[]

  @@unique([slug, userId])
  @@index([userId, updatedAt])
}

// v1.5 Ledger

model ExpenseCategory {
  id         String   @id @default(cuid())
  userId     String
  name       String
  emoji      String   @default("💰")
  color      String   @default("slate")
  isArchived Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@unique([name, userId])
  @@index([userId, isArchived])
}

model Expense {
  id         String    @id @default(cuid())
  userId     String
  categoryId String?
  amount     Int
  currency   String    @default("CNY")
  note       String    @default("")
  occurredAt DateTime  @default(now())
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt])
  @@index([userId, deletedAt])
  @@index([userId, categoryId])
}
