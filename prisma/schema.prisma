generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  name         String
  tokenVersion Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  notes        Note[]
  tags         Tag[]
  dailyNotes   DailyNote[]
  projects     Project[]

  // v1.5 Ledger
  expenseCategories ExpenseCategory[]
  expenses          Expense[]
}

model Note {
  id           String      @id @default(cuid())
  title        String
  content      String      @default("")
  excerpt      String      @default("")
  isFavorite   Boolean     @default(false)
  isPinned     Boolean     @default(false)
  isArchived   Boolean     @default(false)
  deletedAt    DateTime?
  source       String?
  lastViewedAt DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  userId       String
  projectId    String?
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  project      Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  tags         NoteTag[]
  dailyNotes   DailyNote[]
  revisions    NoteRevision[]

  @@index([userId, updatedAt])
  @@index([userId, deletedAt])
  @@index([userId, isArchived])
  @@index([userId, projectId])
}

model NoteRevision {
  id        String   @id @default(cuid())
  noteId    String
  userId    String
  title     String
  content   String
  excerpt   String   @default("")
  reason    String   @default("autosave")
  createdAt DateTime @default(now())

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId, createdAt])
  @@index([userId, createdAt])
}

model Tag {
  id        String    @id @default(cuid())
  name      String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes     NoteTag[]
  createdAt DateTime  @default(now())

  @@unique([name, userId])
}

model NoteTag {
  noteId String
  tagId  String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
}

model DailyNote {
  id        String   @id @default(cuid())
  date      DateTime
  noteId    String
  userId    String
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([date, userId])
  @@index([userId, date])
}

model AISetting {
  id                String   @id @default(cuid())
  userId            String   @unique
  baseUrl           String   @default("https://api.deepseek.com")
  apiKey            String   @default("")
  model             String   @default("deepseek-v4-flash")
  fallbackModel     String   @default("deepseek-v4-pro")
  enableAutoOrganize Boolean @default(true)
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())
}

model MemoryFact {
  id          String    @id @default(cuid())
  userId      String
  type        String    @default("preference")
  content     String
  confidence  Float     @default(0.7)
  isActive    Boolean   @default(true)
  sourceType  String?
  sourceId    String?
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())

  @@index([userId, isActive])
  @@index([userId, type])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  slug        String
  description String   @default("")
  status      String   @default("active")
  color       String   @default("slate")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes       Note[]

  @@unique([slug, userId])
  @@index([userId, updatedAt])
}

// v1.5 Ledger

model ExpenseCategory {
  id         String   @id @default(cuid())
  userId     String
  name       String
  emoji      String   @default("💰")
  color      String   @default("slate")
  isArchived Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@unique([name, userId])
  @@index([userId, isArchived])
}

model Expense {
  id         String    @id @default(cuid())
  userId     String
  categoryId String?
  amount     Int
  currency   String    @default("CNY")
  note       String    @default("")
  occurredAt DateTime  @default(now())
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt])
  @@index([userId, deletedAt])
  @@index([userId, categoryId])
}

// === Leonote v1.6 Briefing ===

model NewsSource {
  id          String   @id @default(cuid())
  kind        String   // rss | json | api
  url         String
  name        String
  category    String   // world | finance | ai_tech
  region      String   @default("global")
  weight      Int      @default(50)
  enabled     Boolean  @default(true)
  lastFetchAt DateTime?
  failCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       NewsItem[]

  @@index([enabled, category])
  @@index([lastFetchAt])
}

model NewsItem {
  id          String     @id @default(cuid())
  sourceId    String
  source      NewsSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  externalId  String
  title       String
  url         String
  imageUrl    String?
  excerpt     String     @default("")
  content     String     @default("")
  author      String?
  publishedAt DateTime
  fetchedAt   DateTime   @default(now())

  category    String     // world | finance | ai_tech
  language    String     @default("zh")
  region      String     @default("global")

  aiSummary   String?
  aiKeyPoints String?    // JSON string: string[]
  aiScore     Float?
  aiTags      String?    // JSON string: string[]

  states      UserBriefingState[]

  @@unique([sourceId, externalId])
  @@index([category, publishedAt])
  @@index([publishedAt])
  @@index([aiScore])
}

model UserBriefingState {
  id             String   @id @default(cuid())
  userId         String
  itemId         String
  item           NewsItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  isRead         Boolean  @default(false)
  isFavorited    Boolean  @default(false)
  isImported     Boolean  @default(false)
  importedNoteId String?
  readAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, itemId])
  @@index([userId, isRead])
  @@index([userId, isFavorited])
  @@index([itemId])
}

model MarketSnapshot {
  id          String   @id @default(cuid())
  symbol      String
  name        String
  category    String   // index_cn | index_global | fx | crypto | rates
  price       Float
  changePct   Float
  changeAbs   Float
  pointsJson  String   @default("[]") // recent points for SVG sparkline
  capturedAt  DateTime @default(now())

  @@index([symbol, capturedAt])
  @@index([category, capturedAt])
}

model BriefingDigest {
  id        String   @id @default(cuid())
  date      DateTime @unique
  summary   String   // JSON: { weekday, dateLabel, weather?, headlines: string[] }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CronRun {
  id        String   @id @default(cuid())
  task      String
  ok        Boolean
  message   String   @default("")
  startedAt DateTime @default(now())
  endedAt   DateTime?

  @@index([task, startedAt])
  @@index([ok, startedAt])
}
